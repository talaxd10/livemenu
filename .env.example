# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
# Use the "Pooled connection" string for production (includes ?pgbouncer=true&connect_timeout=10)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# ── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
# Full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ───────────────────────────────────────────────────────────────────────
# Used by the seed script to build QR code URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
